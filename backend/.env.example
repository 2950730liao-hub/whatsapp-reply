# 数据库配置
DATABASE_URL=sqlite:///./data/whatsapp_crm.db

# WhatsApp 后端选择：neonize 或 cli
WHATSAPP_BACKEND=neonize

# WhatsApp CLI 配置
WHATSAPP_CLI_PATH=whatsapp
WHATSAPP_STORE_DIR=~/.config/whatsapp-cli

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# 安全配置
SECRET_KEY=your-secret-key-change-this
ACCESS_TOKEN_EXPIRE_MINUTES=60

# 通知配置
NOTIFICATION_AGENT_PHONE=+86138xxxxxxxx
